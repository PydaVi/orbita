{
  "lexicon": 1,
  "id": "social.orbita.shelf.item",
  "defs": {
    "main": {
      "type": "record",
      "description": "Uma obra adicionada à estante de alguém.",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["work", "createdAt"],
        "properties": {
          "work": {
            "type": "ref",
            "ref": "#work",
            "description": "Referência externa mínima à obra — sem duplicar metadado, sem record canônico próprio. Ver docs/BETA0-PLAN.md, seção de pesquisa de ecossistema."
          },
          "createdAt": {
            "type": "string",
            "format": "datetime"
          }
        }
      }
    },
    "work": {
      "type": "object",
      "required": ["provider", "id"],
      "properties": {
        "provider": {
          "type": "string",
          "knownValues": ["tmdb-movie", "tmdb-tv", "musicbrainz", "open-library"]
        },
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        }
      }
    }
  }
}
